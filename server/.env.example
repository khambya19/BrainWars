# ─────────────────────────────────────────────────────────────────────────────
# BrainWars Server — Environment Variables
# Copy this file to .env and fill in the values marked REQUIRED.
# Variables marked OPTIONAL have sensible defaults built into config/env.js.
# Never commit your actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
# OPTIONAL — defaults to "development"
NODE_ENV=development

# OPTIONAL — port the HTTP server listens on. Must match VITE_API_URL in the client.
# Default: 5050
PORT=5050

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED — MongoDB connection string
MONGO_URI=mongodb://localhost:27017/brainwars

# ── CORS ─────────────────────────────────────────────────────────────────────
# OPTIONAL — the browser origin allowed to call the API.
# Default: http://localhost:5173 (Vite dev server default)
ALLOWED_ORIGIN=http://localhost:5173

# ── JWT / Auth ───────────────────────────────────────────────────────────────
# REQUIRED — secret used to sign access tokens. Use a long random string.
JWT_SECRET=change-this-to-a-long-random-secret-before-deploying

# OPTIONAL — separate secret for refresh tokens.
# Default: JWT_SECRET + "_refresh" (change this for better security in production)
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret

# OPTIONAL — access token lifetime (jsonwebtoken format: 15m, 1h, etc.)
# Default: 15m
ACCESS_TOKEN_EXPIRY=15m

# OPTIONAL — refresh token lifetime
# Default: 7d
REFRESH_TOKEN_EXPIRY=7d

# OPTIONAL — refresh cookie max-age in milliseconds
# Default: 604800000 (7 days)
# REFRESH_COOKIE_MAX_AGE_MS=604800000

# OPTIONAL — bcrypt salt rounds. Higher = slower but more secure. ≥12 recommended.
# Default: 12
# BCRYPT_SALT_ROUNDS=12

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# OPTIONAL — auth route rate limit window in milliseconds
# Default: 900000 (15 minutes)
# AUTH_RATE_LIMIT_WINDOW_MS=900000

# OPTIONAL — max auth requests per window
# Default: 20
# AUTH_RATE_LIMIT_MAX=20

# ── Password Reset ───────────────────────────────────────────────────────────
# OPTIONAL — reset token validity in milliseconds
# Default: 3600000 (1 hour)
# RESET_TOKEN_EXPIRY_MS=3600000

# OPTIONAL — base URL used to build the password-reset link in the email
# Default: http://localhost:5173
APP_URL=http://localhost:5173

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# OPTIONAL — if all three SMTP_* values are blank, password-reset links are
# printed to the server console instead (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# OPTIONAL — the From address on outgoing emails
# Default: BrainWars <noreply@brainwars.gg>
SMTP_FROM=BrainWars <noreply@brainwars.gg>

# ── Caching ───────────────────────────────────────────────────────────────────
# OPTIONAL — /api/stats cache lifetime in milliseconds
# Default: 30000 (30 seconds)
# STATS_CACHE_TTL_MS=30000

# ── Pagination ────────────────────────────────────────────────────────────────
# OPTIONAL — how many players are returned by GET /api/players/leaderboard
# Default: 10
# LEADERBOARD_LIMIT=10

# OPTIONAL — how many matches are returned by GET /api/players/me/matches
# Default: 10
# RECENT_MATCHES_LIMIT=10

# OPTIONAL — how many players appear in the /api/stats leaderboard preview
# Default: 5
# STATS_LEADERBOARD_LIMIT=5
